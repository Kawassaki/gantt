# Frontend Jira mode
# true  -> frontend mock data only
# false -> call /api/jira endpoints (served by Vite Jira plugin in dev)
VITE_JIRA_MOCK=false

# Jira provider mode for backend plugin
# mock      -> local mock provider
# atlassian -> real OAuth 2.0 (3LO + PKCE) + Jira Cloud APIs
JIRA_PROVIDER_MODE=atlassian

# App base URL used to build Jira callback URI
FRONTEND_BASE_URL=http://localhost:4000

# Callback path handled by backend plugin/serverless API
# Keep this under /api/jira for Vercel deployments.
JIRA_CALLBACK_PATH=/api/jira/auth/callback

# Atlassian OAuth credentials
JIRA_CLIENT_ID=your_client_id
JIRA_CLIENT_SECRET=your_client_secret

# Token encryption key used for encrypted in-memory token payloads
# Use a long random value in production (32+ chars)
JIRA_TOKEN_ENCRYPTION_KEY=replace_with_secure_random_secret

# Optional scope override
# Default: read:jira-user read:jira-work offline_access
JIRA_SCOPES=read:jira-user read:jira-work offline_access
